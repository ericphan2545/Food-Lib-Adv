<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>

  <link rel="stylesheet" href="/public/css/auth.css">
</head>

<body class="auth-page">

<div class="auth-container">

  <div class="auth-left">
    <h2>FoodLib</h2>
    <p>Khám phá và lưu trữ món ăn yêu thích của bạn.</p>
  </div>

  <div class="auth-right">

    <div class="auth-header">
      <div class="logo">
        <span class="logo-text">FoodLib</span>
      </div>
      <h3 class="auth-title">Chào mừng quay lại</h3>
      <p class="auth-subtitle">Đăng nhập để tiếp tục</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <% if (typeof query !== 'undefined' && query.registered) { %>
      <div class="alert alert-success">Đăng ký thành công</div>
    <% } %>

    <form method="post" action="/users/login">
      <input class="auth-input" type="text" name="username" placeholder="Tài khoản" required>
      <input class="auth-input" type="password" name="password" placeholder="Mật khẩu" required>
      <button class="auth-btn">Đăng nhập</button>
    </form>

    <p class="mt-3">
      Chưa có tài khoản?
      <a href="/users/register" class="auth-link">Đăng ký</a>
    </p>

  </div>

</div>

</body>
</html>