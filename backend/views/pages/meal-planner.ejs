<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&family=Libre+Baskerville:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="/public/css/base.css" />
    <link rel="stylesheet" href="/public/css/theme.css" />
    <link rel="stylesheet" href="/public/css/layout.css" />
    <link rel="stylesheet" href="/public/css/meal-planner.css" />
    <link rel="stylesheet" href="/public/css/components.css" />
  </head>
  <body>
    <div class="bg-pattern"></div>

    <%- include('../partials/header') %>

    <div class="main-container">
      <main class="content-area">
        <div class="content-header">
          <h2 class="page-title">🗓️ Thực Đơn Tuần</h2>
          <div class="week-navigation">
            <button class="week-nav-btn" onclick="previousWeek()">◀</button>
            <span class="current-week" id="currentWeek">Tuần 1</span>
            <button class="week-nav-btn" onclick="nextWeek()">▶</button>
          </div>
        </div>

        <div class="nutrition-warning hidden" id="nutritionWarning">
          <span class="warning-icon">⚠️</span>
          <span class="warning-text" id="warningText">Thực đơn chưa cân bằng dinh dưỡng!</span>
        </div>

        <div class="nutrition-summary">
          <div class="nutrition-card">
            <div class="nutrition-icon carbs">🍚</div>
            <div class="nutrition-info">
              <h4>Carbohydrate</h4>
              <span class="value" id="totalCarbs">0</span> <span class="unit">g/ngày</span>
            </div>
          </div>
          <div class="nutrition-card">
            <div class="nutrition-icon protein">🥩</div>
            <div class="nutrition-info">
              <h4>Protein</h4>
              <span class="value" id="totalProtein">0</span> <span class="unit">g/ngày</span>
            </div>
          </div>
          <div class="nutrition-card">
            <div class="nutrition-icon fat">🥑</div>
            <div class="nutrition-info">
              <h4>Chất béo</h4>
              <span class="value" id="totalFat">0</span> <span class="unit">g/ngày</span>
            </div>
          </div>
          <div class="nutrition-card">
            <div class="nutrition-icon fiber">🥬</div>
            <div class="nutrition-info">
              <h4>Chất xơ</h4>
              <span class="value" id="totalFiber">0</span> <span class="unit">g/ngày</span>
            </div>
          </div>
        </div>

        <div class="planner-layout">
          <div id="bmiResult" class="bmi-result-card">
            <div class="bmi-overview">
              <h3 class="bmi-card-title">BMI</h3>
              <div class="bmi-circle">
                <span id="bmiValue" class="bmi-score">0.0</span>
                <span class="bmi-unit">BMI</span>
              </div>
              <p id="bmiCategory" class="bmi-status-text">--</p>
              <button class="btn-recalc" onclick="openSettingsModal()">
                <span>⚙️</span> Cập nhật
              </button>
            </div>

            <div class="bmi-details-grid">
              <div class="stat-item">
                <div class="stat-info">
                  <span class="stat-label">BMR</span>
                  <span id="bmrValue" class="stat-value">0</span>
                </div>
              </div>
              <div class="stat-item">
                <div class="stat-info">
                  <span class="stat-label">TDEE</span>
                  <span id="tdeeValue" class="stat-value">0</span>
                </div>
              </div>
              <div class="stat-item highlight-item">
                <div class="stat-info">
                  <span class="stat-label">Mục tiêu</span>
                  <span id="targetCalories" class="stat-value-large">0</span>
                </div>
              </div>
            </div>
          </div>

          <div class="weekly-calendar">
            <div class="calendar-header">
              <h3 class="calendar-title">Lịch ăn trong tuần</h3>
              <button class="auto-generate-btn" onclick="autoGenerateMeals()">AI tối ưu thực đơn</button>
            </div>
            <div class="days-grid" id="daysGrid"></div>
          </div>
        </div>
      </main>
    </div>

    <div class="modal-overlay" id="settingsModal" style="display: none;">
      <div class="modal settings-modal">
        <div class="modal-header">
          <h3 class="modal-title">📊 Thông tin cơ thể & BMI</h3>
          <button class="modal-close" onclick="closeSettingsModal()">✕</button>
        </div>
        <div class="modal-body">
          <div class="bmi-form-section">
            <p class="bmi-form-helper">
              Cập nhật thông tin cơ thể để AI tối ưu năng lượng và thực đơn chính xác hơn.
            </p>

            <div class="form-group">
              <label class="form-label">Giới tính</label>
              <div class="gender-options">
                <div class="gender-option" data-gender="male" onclick="selectGender('male')">
                  <div class="icon">👨</div>
                  <div class="label">Nam</div>
                </div>
                <div class="gender-option" data-gender="female" onclick="selectGender('female')">
                  <div class="icon">👩</div>
                  <div class="label">Nữ</div>
                </div>
              </div>
            </div>

            <div class="bmi-grid-2">
              <div class="form-group">
                <label class="form-label">Tuổi</label>
                <div class="input-wrapper">
                  <input type="number" class="input-field" id="age" placeholder="25" min="10" max="100" />
                  <span class="input-unit">tuổi</span>
                </div>
              </div>

              <div class="form-group">
                <label class="form-label">Chiều cao</label>
                <div class="input-wrapper">
                  <input type="number" class="input-field" id="height" placeholder="170" min="100" max="250" />
                  <span class="input-unit">cm</span>
                </div>
              </div>

              <div class="form-group">
                <label class="form-label">Cân nặng</label>
                <div class="input-wrapper">
                  <input type="number" class="input-field" id="weight" placeholder="65" min="30" max="300" />
                  <span class="input-unit">kg</span>
                </div>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Mức độ vận động</label>
              <div class="activity-options">
                <div class="activity-option" data-level="sedentary" onclick="selectActivity('sedentary')">
                  <div class="radio"></div>
                  <span class="text">Ít vận động</span>
                </div>
                <div class="activity-option" data-level="light" onclick="selectActivity('light')">
                  <div class="radio"></div>
                  <span class="text">Vận động nhẹ</span>
                </div>
                <div class="activity-option" data-level="moderate" onclick="selectActivity('moderate')">
                  <div class="radio"></div>
                  <span class="text">Vận động vừa</span>
                </div>
                <div class="activity-option" data-level="active" onclick="selectActivity('active')">
                  <div class="radio"></div>
                  <span class="text">Vận động nhiều</span>
                </div>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Số bữa mục tiêu mỗi ngày</label>
              <div class="input-wrapper">
                <select class="input-field" id="mealsPerDay">
                  <option value="3">3 bữa (Sáng - Trưa - Tối)</option>
                  <option value="4">4 bữa (thêm bữa phụ)</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Chế độ ăn (tuỳ chọn)</label>
              <div class="input-wrapper">
                <input type="text" class="input-field" id="dietaryPreferences" placeholder="Ví dụ: ăn chay, low-carb, không lactose" />
              </div>
            </div>

            <div class="form-group">
              <label class="form-label">Dị ứng/không ăn (tuỳ chọn)</label>
              <div class="input-wrapper">
                <input type="text" class="input-field" id="allergyNotes" placeholder="Ví dụ: dị ứng tôm, không ăn cay" />
              </div>
            </div>

            <div class="bmi-action-bar">
              <button class="calculate-btn" onclick="calculateBMI()">
                <span>✨</span> Tính toán & Lưu
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="modal-overlay" id="foodModal" style="display: none;">
      <div class="modal">
        <div class="modal-header">
          <h3 class="modal-title" id="modalTitle">Chọn món ăn - Bữa sáng</h3>
          <button class="modal-close" onclick="closeModal()">✕</button>
        </div>
        <div class="modal-body">
          <div class="food-filter-tabs">
            <button class="filter-tab active" onclick="filterFood('all')">Tất cả</button>
            <button class="filter-tab" onclick="filterFood('carbs')">Tinh bột</button>
            <button class="filter-tab" onclick="filterFood('protein')">Đạm</button>
            <button class="filter-tab" onclick="filterFood('fat')">Chất béo</button>
            <button class="filter-tab" onclick="filterFood('fiber')">Chất xơ</button>
            <button class="filter-tab" onclick="filterFood('balanced')">Cân bằng</button>
          </div>
          <div class="food-grid" id="foodGrid"></div>
        </div>
      </div>
    </div>

    <button class="theme-toggle" aria-label="Toggle theme">
      <span class="icon-light">🌙</span>
      <span class="icon-dark">☀️</span>
    </button>

    <button
      type="button"
      onclick="openAiModal()"
      aria-label="Mở AI tư vấn"
      title="Mở AI tư vấn"
      style="
        position: fixed;
        right: 18px;
        bottom: 86px;
        width: 52px;
        height: 52px;
        border-radius: 999px;
        border: none;
        background: linear-gradient(135deg, #2e7d32, #43a047);
        color: #fff;
        box-shadow: 0 10px 24px rgba(0,0,0,0.18);
        cursor: pointer;
        z-index: 2500;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
      "
    >
      🤖
    </button>

    <div id="recipe-modal" class="modal-overlay" style="display: none; z-index: 2000;">
      <div class="modal" style="max-width: 800px; width: 90%; margin: 2rem auto; max-height: 90vh; overflow-y: auto;">
        <div class="modal-header">
          <h3 class="modal-title">Chi tiết công thức</h3>
          <div class="modal-header-actions">
            <div class="food-favorite favorite-btn recipe-modal-fav"><span>❤️</span></div>
            <button type="button" class="modal-close" onclick="closeRecipeModal()" aria-label="Đóng">✕</button>
          </div>
        </div>
        <div class="modal-body" id="modal-body-content"></div>
      </div>
    </div>

    <div class="modal-overlay" id="warningModal" style="display: none;">
      <div class="modal modal-warning">
        <div class="modal-header warning-header">
          <div class="warning-icon">⚠️</div>
        </div>
        <div class="modal-body warning-body">
          <h3 class="modal-title warning-title">Chưa có thông tin cơ thể</h3>
          <p class="warning-text">
            Bạn cần cập nhật chỉ số cơ thể (BMI/TDEE) trước khi để hệ thống tự động tạo thực đơn. Bạn có muốn mở cài đặt ngay không?
          </p>
          <div class="modal-actions warning-actions">
            <button class="btn-cancel" onclick="closeWarningModal()">Để sau</button>
            <button class="btn-confirm" onclick="confirmOpenSettings()">
              <span>⚙️</span> Mở cài đặt
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="modal-overlay" id="aiModal" style="display: none;">
      <div class="modal ai-meal-modal" style="max-width: 960px; width: 92%; margin: 2rem auto;">
        <div class="modal-header">
          <h3 class="modal-title">🤖 AI Planner theo nguyên liệu tuần & BMI</h3>
          <button class="modal-close" onclick="closeAiModal()">✕</button>
        </div>
        <div class="modal-body">
          <div class="ai-modal-grid">
            <section class="ai-modal-card">
              <h4 class="ai-step-title">1) Nguyên liệu bạn có trong tuần</h4>
              <p class="ai-step-note">
                Gõ tự nhiên theo dòng hoặc phân tách bằng dấu phẩy. Ví dụ: "2kg ức gà, 10 trứng, 1 bó cải xanh, 500g cá hồi".
              </p>
              <textarea
                class="input-field ai-ingredients-textarea"
                id="aiIngredientsInput"
                placeholder="Nhập nguyên liệu có sẵn cho cả tuần..."
              ></textarea>
            </section>
            <section class="ai-modal-card">
              <h4 class="ai-step-title">2) Hồ sơ BMI đã tối ưu</h4>
              <p class="ai-step-note">
                AI sẽ dùng hồ sơ cơ thể hiện tại để tối ưu năng lượng và macro. Nếu chưa có dữ liệu, hãy bấm "Cập nhật BMI".
              </p>
              <div id="aiProfileSummary" class="ai-profile-summary"></div>
              <div class="form-group" style="margin-bottom: 10px;">
                <label class="form-label">Ghi chú thêm (tuỳ chọn)</label>
                <input class="input-field" id="aiNoteInput" placeholder="Ví dụ: không ăn cay, dị ứng tôm..." />
              </div>
              <button class="auto-generate-btn" style="width:100%;" onclick="requestAiAdvice()">Tạo thực đơn AI 7 ngày</button>
              <div id="aiAdviceStatus" style="margin-top: 10px; color: var(--text-muted); font-size: 0.95rem;"></div>
            </section>
          </div>

          <div style="margin-top: 16px;">
            <h4 style="margin: 0 0 8px;">3) Kết quả tư vấn AI</h4>
            <div id="aiAdviceResult" style="border: 1px solid rgba(0,0,0,0.08); border-radius: 12px; padding: 12px; min-height: 120px; background: rgba(255,255,255,0.6);"></div>
            <div style="margin-top: 10px; display: flex; justify-content: flex-end;">
              <button id="applyAiPlanBtn" class="auto-generate-btn" style="display:none;" onclick="applyAiPlanToCurrentWeek()">
                Áp dụng vào lịch tuần hiện tại
              </button>
            </div>
          </div>

          <div style="margin-top: 14px;">
            <h4 style="margin: 0 0 8px;">4) Lịch sử gợi ý AI</h4>
            <div id="aiHistoryList" class="ai-history-list"></div>
          </div>
        </div>
      </div>
    </div>

    <div id="toast" class="toast">
      <div class="toast-icon">✅</div>
      <div class="toast-body">
        <h4 class="toast-title">Thành công!</h4>
        <p class="toast-message">Đã cập nhật chỉ số BMI & TDEE.</p>
      </div>
    </div>

    <script>
      window.CURRENT_USER = <%- JSON.stringify(currentUser || null) %>;
    </script>
    <script src="/public/js/nav-indicator.js"></script>
    <script src="/public/js/theme.js"></script>
    <script src="/public/js/food-database.js"></script>
    <script src="/public/js/recipes.js"></script>
    <script src="/public/js/recipes-ui.js"></script>
    <script src="/public/js/meal-planner.js"></script>
  </body>
</html>

