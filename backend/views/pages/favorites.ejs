<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>

    <link rel="stylesheet" href="/public/css/base.css">
    <link rel="stylesheet" href="/public/css/layout.css">
    <link rel="stylesheet" href="/public/css/components.css">
    <link rel="stylesheet" href="/public/css/theme.css">
    <link rel="stylesheet" href="/public/css/favorites.css">
</head>
<body class="bg-pattern">
    <%- include('../partials/header') %>

    <main class="main-content favorites-page">
        <section class="favorites-hero" aria-labelledby="favorites-heading">
            <div class="favorites-hero-top">
                <div>
                    <h2 id="favorites-heading">Món ăn yêu thích</h2>
                    <p class="favorites-subtitle">Danh sách được lưu trên trình duyệt của bạn. Nhấn vào trái tim trên thẻ món để bỏ yêu thích, hoặc mở công thức để xem chi tiết.</p>
                </div>
                <span class="favorites-count-pill" aria-live="polite"><span aria-hidden="true">❤️</span> <span id="favoriteCount">Chưa có món ăn nào được yêu thích</span></span>
            </div>
        </section>

        <div class="favorites-grid-wrap">
            <div class="grid grid-4 favorites-grid" id="favoritesGrid" style="display: none;"></div>
        </div>

        <div id="emptyState" class="favorites-empty" style="display: none;">
            <div class="favorites-empty-icon" aria-hidden="true">💔</div>
            <h3>Chưa có món yêu thích</h3>
            <p>Thêm món từ trang chủ bằng cách nhấn biểu tượng trái tim trên thẻ món hoặc trong cửa sổ chi tiết công thức.</p>
            <a href="/" class="btn btn-primary btn-rounded">Khám phá món ăn</a>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <button class="theme-toggle" aria-label="Toggle theme">
        <span class="icon-light">🌙</span>
        <span class="icon-dark">☀️</span>
    </button>

    <div id="recipe-modal" class="modal-overlay" style="display: none;">
        <div class="modal recipe-modal-panel">
            <div class="modal-header">
                <h3 class="modal-title">Chi tiết công thức</h3>
                <div class="modal-header-actions">
                    <div class="food-favorite favorite-btn recipe-modal-fav"><span>❤️</span></div>
                    <button type="button" class="modal-close" onclick="closeRecipeModal()" aria-label="Đóng">✕</button>
                </div>
            </div>
            <div class="modal-body" id="modal-body-content"></div>
        </div>
    </div>

    <script>
      window.CURRENT_USER = <%- JSON.stringify(currentUser || null) %>;
    </script>
    <script src="/public/js/nav-indicator.js"></script>
    <script src="/public/js/theme.js"></script>
    <script src="/public/js/food-database.js"></script>
    <script src="/public/js/recipes.js"></script>
    <script src="/public/js/recipes-ui.js"></script>
    <script src="/public/js/favorites.js"></script>
</body>
</html>
