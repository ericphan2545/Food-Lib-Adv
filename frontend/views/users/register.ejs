<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title><%= title %></title>

  <link rel="stylesheet" href="/public/css/auth.css">
</head>

<body class="auth-page">

<div class="auth-container">

  <div class="auth-left">
    <h2>FoodLib</h2>
    <p>Bắt đầu hành trình ẩm thực của bạn ngay hôm nay.</p>
  </div>

  <div class="auth-right">

    <div class="auth-header">
      <div class="logo">
        <span class="logo-text">FoodLib</span>
      </div>
      <h3 class="auth-title">Tạo tài khoản</h3>
      <p class="auth-subtitle">Đăng ký để bắt đầu</p>
    </div>

    <% if (error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form method="post" action="/users/register">
      <input class="auth-input" type="email" name="email" placeholder="Email" required>
      <input class="auth-input" type="text" name="username" placeholder="Tài khoản" required>
      <input class="auth-input" type="password" name="password" placeholder="Mật khẩu" required>
      <button class="auth-btn">Đăng ký</button>
    </form>

    <p class="mt-3">
      Đã có tài khoản?
      <a href="/users/login" class="auth-link">Đăng nhập</a>
    </p>

  </div>

</div>

</body>
</html>